DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plusai"

S3_BUCKET_ACCESS_KEY = "s3-bucket-access-key"
S3_BUCKET_SECRET_KEY = "s3-bucket-secret-key"
AWS_REGION = "ap-south-1"
AWS_BUCKET = "bucket-name"